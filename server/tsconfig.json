{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["server.js", "src/**/*.js", "src/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules"]
}
