{
  "name": "condo-desktop-launcher",
  "version": "1.0.0",
  "private": true,
  "description": "Electron launcher for the Condo Management Portal desktop Docker bundle.",
  "main": "main.js",
  "productName": "Condo Desktop Launcher",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "package:win": "electron-forge package --platform=win32",
    "package:mac": "electron-forge package --platform=darwin",
    "package:linux": "electron-forge package --platform=linux"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "electron": "^36.0.0"
  }
}
